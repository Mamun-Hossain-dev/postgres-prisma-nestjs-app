model Product {
  id        Int            @id @default(autoincrement())
  title     String
  price     Float
  quantity  Int
  images    ProductImage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("products")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  url       String
  publicId  String   @unique
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}
